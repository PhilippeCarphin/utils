#!/usr/bin/env bash

main(){
    # Switch to alternate buffer
    printf "\033[?1049h" >&2
    trap 'kill ${TAIL_PID} ; wait ; printf "\033[?1049l" >&2' EXIT
    trap "winch '$1'" WINCH

    prepare-display $1

    while true ; do
        tail -f -n ${LINES} $1 &
        TAIL_PID=$!
        wait
    done
}

winch(){
    kill ${TAIL_PID} ; wait
    printf "\033[2J" >&2
    prepare-display $1
}

prepare-display(){
    LINES=$(tput lines)

    local cols=$(tput cols)
    local header_text="Tailing $1"
    local hbar spaces

    printf -v hbar "\u2550"
    printf -v spaces "%${cols}s"
    local hrule=${spaces//?/$hbar}
    local x0=$(((cols - ${#header_text} )/ 2))
    printf "\033[2J\033[4;%dr\033[1;H%s\033[2;${x0}H%s\033[3;H%s\033[4;H" \
        "${LINES}" "${hrule}" "${header_text}" "${hrule}"
}

main "$@"
