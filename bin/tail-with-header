#!/usr/bin/env bash

main(){
    error-checks "$@" || return

    # Switch to alternate buffer
    printf "\033[?1049h" >&2
    trap 'kill ${TAIL_PID} ; wait ; printf "\033[?1049l" >&2' EXIT
    trap "winch '$1'" WINCH

    prepare-display $1

    while true ; do
        tail -f -n $(tput lines) $1 &
        TAIL_PID=$!
        wait
    done
}

winch(){
    kill ${TAIL_PID} ; wait
    printf "\033[2J" >&2
    prepare-display $1
}

prepare-display(){
    local cols=$(tput cols)

    printf "\e[4;r" >&2

    local hbar spaces
    printf -v hbar "\u2550"
    printf -v spaces "%${cols}s"
    local hrule=${spaces//?/$hbar}

    local header_text="Tailing $1"
    local x0=$(((cols - ${#header_text} )/ 2))

    printf "\e[1;H%s\e[2;${x0}H%s\e[3;H%s\e[4;H" \
        "${hrule}" "${header_text}" "${hrule}"
}

error-checks(){
    if (( $# < 1 )) ; then
        printf "${0##*/}: ERROR: A file is required\n" >&2
        return 1
    fi

    if ! [[ -f $1 ]] ; then
        printf "${0##*/}: ERROR: Cannot tail '%s': No such file\n" "$1" >&2
        return 1
    fi

    if (( $(tput lines) < 6 )) ; then
        printf "${0##*/}: ERROR: Window too small\n" >&2
        return 1
    fi
}

main "$@"
