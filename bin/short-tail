#!/usr/bin/env bash
SIZE=10
main(){
    LINES=$(tput lines)
    cols=$(tput cols)
    space $SIZE
    # get-cursor sometimes causes characters to be
    # echoed when the get-cursor happens after C-c
    set-scroll
    stty -echo
    trap 'reset-scroll ; stty echo' EXIT
    trap 'echo "^C" ; exit 130' INT
    tail -f $1 >&2
}

get-cursor(){
    local pos
    printf "\033[6n" >&2
    read -u 0 -s -d R pos
    # printf "%q\n" "${pos}"
    pos=${pos#*'['}
    row=${pos%;*}
    col=${pos#*;}
}

set-scroll(){
    get-cursor
    printf "\033[${row};$((row + SIZE))r" >&2
    printf "\033[${row};${col}H" >&2
}

reset-scroll(){
    get-cursor
    printf "\033[1;$(tput lines)r" >&2
    printf "\033[${row};${col}H" >&2
}

space(){
    local spaces lines
    printf -v spaces "%${1}s"
    printf "%s\033[${1}A" "${spaces//?/$'\n'}" >&2
}

main "$@"
