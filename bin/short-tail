#!/usr/bin/env bash
SIZE=10
main(){
    error-checks "$@" || return

    space $SIZE

    set-scroll
    trap 'reset-scroll' EXIT

    tail -f $1 >&2
}

get-cursor(){
    local pos
    printf "\033[6n" >&2
    read -u 0 -s -d R pos
    pos=${pos#*'['}
    row=${pos%;*}
    col=${pos#*;}
}

set-scroll(){
    get-cursor
    printf "\e7\e[${row};$((row+SIZE))r\e8" >&2
}

reset-scroll(){
    printf "\e7\e[r\e8" >&2
}

space(){
    local spaces lines
    printf -v spaces "%${1}s"
    printf "%s\033[${1}A" "${spaces//?/$'\n'}" >&2
}

error-checks(){
    if (( $# < 1 )) ; then
        printf "${0##*/}: ERROR: A file is required\n" >&2
        return 1
    fi

    if ! [[ -f $1 ]] ; then
        printf "${0##*/}: ERROR: Cannot tail '%s': No such file\n" "$1" >&2
        return 1
    fi
}

main "$@"
