#!/usr/bin/env bash
SIZE=10

if (( $# < 1 )) ; then
    printf "${0##*/}: ERROR: A file is required\n" >&2
    exit 1
elif ! [[ -f $1 ]] ; then
    printf "${0##*/}: ERROR: Cannot tail '%s': No such file\n" "$1" >&2
    exit 1
fi

# Print $SIZE newlines
printf -v spaces "%${SIZE}s"
printf "%s\033[${SIZE}A" "${spaces//?/$'\n'}" >&2

# Get cursor current row
printf "\033[6n" >&2
read -u 0 -s -d R pos
pos=${pos#*'['}
row=${pos%;*}

# Set scroll region and reset on exit
printf "\e7\e[${row};$((row+SIZE))r\e8" >&2
trap 'printf "\e7\e[r\e8" >&2' EXIT

tail -f $1 >&2
