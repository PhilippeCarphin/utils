#!/usr/bin/env python3

import sys
import re
import argparse

ansi = re.compile(r'\x1b\[[0-7;]*m')
color_index = 20
token_colors = {}
def get_args():
    p = argparse.ArgumentParser()
    p.add_argument("-f", "--field", type=int, help="Field number", required=True)
    p.add_argument("-a", "--also", type=str)
    p.add_argument("--all", action='store_true', help="Color whole line instead of just the given field")
    p.add_argument("--header", type=int, default=0, help="Start coloring at line N")
    return p.parse_args()

def next_color():
    global color_index
    color_index += 3
    if color_index > 231:
        color_index = 20
    return color_index

def split_including_delim(string, delim=' '):
    words = []
    word = ""
    ic = iter(string)
    try:
        while True:
            c = next(ic)
            word += c
            if c == delim:
                # Consume delimiters until we find the first char of the next
                # word.
                while True:
                    c = next(ic)
                    if c != delim:
                        words.append(word)
                        word = c
                        break
                    else:
                        word += c
    except StopIteration:
        words.append(word)
    return words

def main():
    lineno = 0
    args = get_args()
    for l in sys.stdin:
        lineno += 1
        if lineno <= args.header:
            print(l, end='')
            continue
        words = split_including_delim(l.strip(), ' ')
        if len(words) <= args.field:
            print(l.strip())
            # print("lineno #{lineno} only has {len(words)} fields")
            continue

        h = ansi.sub('', words[args.field])
        if h in token_colors:
            color = token_colors[h]
        else:
            color = next_color()
            token_colors[h] = color

        if args.all:
            print(f"\033[38;5;{color}m{l.strip()}\033[0m")
        else:
            words[args.field] = f"\033[38;5;{color}m{h}\033[0m"
            if args.also:
                if args.also.endswith('+'):
                    n = int(args.also[:-1])
                    trail = ''.join(words[n:])
                    trail = ansi.sub('', trail)
                    words = words[:n]
                    color_trail=f"\033[38;5;{color}m{trail}\033[0m"
                    words.append(color_trail)
                else:
                    if len(words) <= args.also:
                        words[int(args.also)] = f"\033[38;5;{color}m{words[int(args.also)]}\033[0m"
            print(''.join(words))

if __name__ == "__main__":
    sys.exit(main())
